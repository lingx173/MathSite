# n8n webhook for practice question generation (required for "Generate 10 Questions" on production).
# Get your webhook URL from your n8n workflow (Webhook node).
# In Vercel: Settings → Environment Variables → add N8N_PRACTICE_WEBHOOK_URL.
N8N_PRACTICE_WEBHOOK_URL=https://your-instance.app.n8n.cloud/webhook-test/your-webhook-path
