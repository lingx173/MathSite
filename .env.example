# n8n webhook for practice question generation ("Generate 5 Questions").
# Use either variable; the API route checks N8N_PRACTICE_WEBHOOK_URL first, then NEXT_PUBLIC_N8N_WEBHOOK_URL.
# Local: copy this file to .env.local and set the value. Vercel: Settings → Environment Variables.

# Server-side (recommended; URL not exposed to client). Use production webhook.
N8N_PRACTICE_WEBHOOK_URL=https://ling-xue-uga.app.n8n.cloud/webhook/math-practice

# Or use the same pattern as the Debate site (available in client and server)
# NEXT_PUBLIC_N8N_WEBHOOK_URL=https://ling-xue-uga.app.n8n.cloud/webhook/math-practice
